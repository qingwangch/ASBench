/*
 * =========================================================
 *  WEHI Milton HPC — Slurm  +  Singularity (Apptainer)
 * =========================================================
 */
params {
    config_profile_description = 'WEHI Milton HPC – Slurm + Singularity profile'
    config_profile_contact     = 'Jacob Munro <munro.j@wehi.edu.au>'
    config_profile_url         = 'https://www.wehi.edu.au/'
}

/* ------------------------------------------------------------------
 *  Global process defaults (can be overridden with directives)
 * ------------------------------------------------------------------ */
process {
    executor       = 'slurm'          // Slurm is the site scheduler
    queue          = 'regular'        // default partition
    time           = '48h'            // wall-time limit
    memory         = '128 GB'         // RAM per job
    cpus           = 8                // CPU cores per job
    cache          = 'lenient'        // allow task reuse if inputs match

    /* Give Slurm jobs a useful name:  <process> (<sample>) */
    clusterOptions = '-J "$task.process ($task.tag)"'
}

/* ------------------------------------------------------------------
 *  Slurm executor tuning
 * ------------------------------------------------------------------ */
executor {
    queueSize         = 100           // max jobs submitted at once
    pollInterval      = '10 sec'      // how often NF polls Slurm
    queueStatInterval = '30 sec'      // how often NF polls queue status
    submitRateLimit   = '10 sec'      // throttle sbatch rate
}

/* ------------------------------------------------------------------
 *  Singularity / Apptainer engine settings
 * ------------------------------------------------------------------ */
singularity {
    enabled      = true                           // turn container mode on
    autoMounts   = true                           // bind $PWD, /home, /tmp
    runOptions   = '-B /vast:/vast -B /stornext:/stornext'        // bind project filesystems
    cacheDir     = "/vast/projects/quartet_rna_refdata/github/ASBench/sing_cache"
}

/* ------------------------------------------------------------------
 *  Named configuration profiles
 * ------------------------------------------------------------------ */
profiles {

    /* Production runs:  Slurm + Singularity */
    wehi {
        /* inherits all global process and singularity settings */
    }

    /* Keep work dirs, command scripts and full trace for debugging */
    debug {
        cleanup       = false
        process.trace = true
    }
}